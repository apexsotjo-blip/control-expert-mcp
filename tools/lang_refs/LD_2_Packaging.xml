	<program>
		<identProgram name="Packaging" type="section" task="MAST"></identProgram>
		<LDSource nbColumns="11">
			<networkLD>
				<typeLine>
					<contact typeContact="PContact" contactVariableName="hb_five"></contact>
					<shortCircuit>
						<VLink></VLink>
						<HLink nbCells="9"></HLink>
					</shortCircuit>
					<coil typeCoil="setCoil" coilVariableName="five_pices"></coil>
				</typeLine>
				<typeLine>
					<emptyCell nbCells="10"></emptyCell>
					<coil typeCoil="resetCoil" coilVariableName="ten_pices"></coil>
				</typeLine>
				<typeLine>
					<emptyLine nbRows="1"></emptyLine>
				</typeLine>
				<typeLine>
					<contact typeContact="PContact" contactVariableName="hb_ten"></contact>
					<shortCircuit>
						<VLink></VLink>
						<HLink nbCells="9"></HLink>
					</shortCircuit>
					<coil typeCoil="setCoil" coilVariableName="ten_pices"></coil>
				</typeLine>
				<typeLine>
					<emptyCell nbCells="10"></emptyCell>
					<coil typeCoil="resetCoil" coilVariableName="five_pices"></coil>
				</typeLine>
				<typeLine>
					<emptyLine nbRows="95"></emptyLine>
				</typeLine>
			</networkLD>
		</LDSource>
	</program>
	<dataBlock>
		<variables name="five_pices" typeName="BOOL">
			<comment>Packaging 5 pices</comment>
		</variables>
		<variables name="hb_five" typeName="EBOOL">
			<comment>Internal Bit for five pieces</comment>
		</variables>
		<variables name="ten_pices" typeName="BOOL">
			<comment>Packaging 10 pices</comment>
		</variables>
		<variables name="hb_ten" typeName="EBOOL">
			<comment>Internal Bit for ten pieces</comment>
		</variables>
	</dataBlock>
</LDExchangeFile>
