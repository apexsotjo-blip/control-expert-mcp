	<program>
		<identProgram name="Alarming" type="section" task="MAST"></identProgram>
		<ILSource>(* Alert for temperature to low *)

CAL Temperature_monitoring_1 (
  COND1 := 1,
  COND0 := Temp_fault_1,
  ERROR =&gt; Alert_1
  )

(* Alert for temperature to high *)

CAL Temperature_monitoring_2 (
  COND1 := 1,
  COND0 := Temp_fault_2,
  ERROR =&gt; Alert_2
  )

(* Warning for feeder empty *)

CAL Feeder_monitoring (
  COND1 := 1,
  COND0 := new_material_demand,
  ERROR =&gt; Alert_3
  )
</ILSource>
	</program>
